      <div class="fr3"><div class="fg"><label>Prefix</label><select id="ag-prefix"><option></option><option>Mr.</option><option>Mrs.</option><option>Ms.</option></select></div><div class="fg" style="grid-column:span 2"><label>First Name <span class="req">*</span></label><input id="ag-fname" placeholder="First Name"><div class="errmsg">Required</div></div></div>
      <div class="fr"><div class="fg"><label>Middle Name</label><input id="ag-mname" placeholder="Middle Name"></div><div class="fg"><label>Last Name <span class="req">*</span></label><input id="ag-lname" placeholder="Last Name"><div class="errmsg">Required</div></div></div>
      <div class="fr"><div class="fg"><label>Suffix</label><input id="ag-suffix" placeholder="e.g. Jr."></div><div class="fg"><label>Nick Name</label><input id="ag-nick" placeholder="Nick Name"></div></div>
      <label class="chk-row"><input type="checkbox" id="ag-active" checked> Is Active</label>
     </div>
     <div class="avatar-box" onclick="toast('📷 Photo upload','warn')"><span>👤</span><p>Click to<br>upload photo</p></div>
    </div>
   </div>
   <!-- Personal Info -->
   <div class="msec">
    <div class="msec-title">Personal Info</div>
    <div class="fr"><div class="fg"><label>Sex</label><select id="ag-sex"><option>Female</option><option>Male</option></select></div><div class="fg"><label>Contact No.</label><input id="ag-contact" placeholder="Contact No."></div></div>
    <div class="fr"><div class="fg"><label>Birth Date</label><input type="date" id="ag-bdate"></div><div class="fg"><label>Email</label><input type="email" id="ag-email" placeholder="Email"></div></div>
    <div class="fg"><label>Civil Status</label><select id="ag-civil" style="max-width:300px"><option>Single</option><option>Married</option><option>Widowed</option><option>Separated</option></select></div>
   </div>
   <!-- Other Info -->
   <div class="msec">
    <div class="msec-title">Other Info</div>
    <div class="fg"><label>Agent Type</label><select id="ag-type"><option></option><option>Full-Time</option><option>Part-Time</option><option>Commission</option></select></div>
    <div class="fg"><label>Address</label><textarea id="ag-addr" placeholder="Full address..."></textarea></div>
    <div class="fg"><label>Branch Name</label><input id="ag-branch" value="Malolos"></div>
   </div>
   <div class="meta-bar"><span>Created: —</span><span>Updated: —</span></div>
  </div>
  <div class="mft">
   <button class="btn btn-secondary" onclick="closeM('m-agent')">✕ Cancel</button>
   <button class="btn btn-primary" onclick="saveAgent()">💾 Save Agent</button>
  </div>
 </div>
</div>

<!-- ⑪ ADDRESS MODAL -->
<div class="overlay" id="m-address">
 <div class="modal sm">
  <div class="mhd">
   <div class="mhd-left"><div class="mhd-icon" style="background:rgba(14,165,233,.15)">📍</div><div><div class="mhd-title" id="m-addr-title">Address Info</div><div class="mhd-sub">Add address record</div></div></div>
   <div class="mc" onclick="closeM('m-address')">✕</div>
  </div>
  <div class="mbody">
   <div class="msec">
    <div class="msec-title">Address Info</div>
    <div class="fg"><label>Code <span class="req">*</span></label><input id="addr-code" placeholder="e.g. A2015rW853"><div class="errmsg">Required</div></div>
    <div class="fg"><label>Address <span class="req">*</span></label><textarea id="addr-addr" placeholder="Full address: Barangay, City, Province..."><div class="errmsg">Required</div></textarea></div>
    <label class="chk-row"><input type="checkbox" id="addr-active" checked> Is Active</label>
   </div>
   <div class="meta-bar"><span>Created: —</span><span>Updated: —</span></div>
  </div>
  <div class="mft">
   <button class="btn btn-secondary" onclick="closeM('m-address')">✕ Cancel</button>
   <button class="btn btn-primary" onclick="saveAddress()">💾 Save Address</button>
  </div>
 </div>
</div>

<!-- ⑫ LOOKUP INFO (Image 19) -->
<div class="overlay" id="m-lookup">
 <div class="modal sm">
  <div class="mhd">
   <div class="mhd-left"><div class="mhd-icon" style="background:rgba(14,165,233,.15)">🔎</div><div><div class="mhd-title" id="m-lu-title">Look Up Info</div><div class="mhd-sub">Add lookup record</div></div></div>
   <div class="mc" onclick="closeM('m-lookup')">✕</div>
  </div>
  <div class="mbody">
   <div class="msec">
    <div class="msec-title">Look Up Info</div>
    <div class="fg"><label>Category</label><select id="lu-category"><option>Name</option><option>Status</option><option>Type</option><option>Pension Type</option><option>Civil Status</option><option>Nationality</option></select></div>
    <div class="fg"><label>LookUpWord <span class="req">*</span></label><input id="lu-word" placeholder="Look Up Word"><div class="errmsg">The LookUpWord field is required.</div></div>
    <div class="fg"><label>Order By</label><input id="lu-order" type="number" placeholder="Order By"></div>
    <div class="fg"><label>Code</label><input id="lu-code" placeholder="Code"></div>
    <label class="chk-row"><input type="checkbox" id="lu-active" checked> Is Active</label>
   </div>
   <div class="meta-bar"><span>Created: —</span><span>Updated: —</span></div>
  </div>
  <div class="mft">
   <button class="btn btn-secondary" onclick="closeM('m-lookup')">✕ Cancel</button>
   <button class="btn btn-primary" onclick="saveLookup()">💾 Save</button>
  </div>
 </div>
</div>

<!-- CONFIRM MODAL -->
<div class="overlay" id="m-confirm">
 <div class="confirm-box">
  <div class="confirm-ico">⚠️</div>
  <div class="confirm-title" id="confirm-title">Confirm Action</div>
  <div class="confirm-msg" id="confirm-msg">Are you sure?</div>
  <div class="confirm-btns">
   <button class="btn btn-secondary" onclick="closeM('m-confirm')">Cancel</button>
   <button class="btn btn-danger" id="confirm-ok">Confirm</button>
  </div>
 </div>
</div>

