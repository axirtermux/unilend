<!-- REPORT PAGES -->
<div class="page" id="page-rep_cf"><div class="ph-title" style="margin-bottom:18px">Change Fund Register</div><div class="rf"><div class="rf-grid"><div class="fg"><label>Date From <span class="req">*</span></label><input type="date" value="2026-04-27"></div><div class="fg"><label>Date To <span class="req">*</span></label><input type="date" value="2026-04-27"></div><div class="fg"><label>Branch</label><select><option>— All Branches —</option><option selected>Malolos</option></select></div><div class="fg"><label>Customer</label><input placeholder="Search customer..."></div></div><div class="fg" style="margin-top:10px"><div class="rrow"><label class="ri"><input type="radio" name="rcf" checked> Group by branch</label><label class="ri"><input type="radio" name="rcf"> Show as list</label></div></div><div style="display:flex;gap:8px;margin-top:14px"><button class="btn btn-primary" onclick="toast('📊 Report generated!','success')">🔍 View Report</button><button class="btn btn-danger" onclick="toast('📥 Downloading PDF...','success')">📥 Download PDF</button><button class="btn btn-secondary" onclick="toast('🧹 Cleared','success')">Clear</button></div></div></div>
<div class="page" id="page-rep_check"><div class="ph-title" style="margin-bottom:18px">Check Register</div><div class="rf"><div class="rf-grid"><div class="fg"><label>Date From</label><input type="date" value="2026-04-27"></div><div class="fg"><label>Date To</label><input type="date" value="2026-04-27"></div><div class="fg"><label>Bank</label><select><option>— All Banks —</option><option>PNB</option><option>BDO</option><option>BPI</option></select></div><div class="fg"><label>Disbursement Type</label><select><option>— All Types —</option><option>Check</option><option>Cash</option></select></div><div class="fg"><label>Payee</label><input placeholder="Search payee..."></div><div class="fg"><label>Trans / CV No</label><input placeholder="Voucher number"></div><div class="fg"><label>Cheque No</label><input placeholder="Cheque number"></div></div><label class="chk-row" style="margin-top:10px"><input type="checkbox"> Exclude Bonus Transactions</label><div style="display:flex;gap:8px;margin-top:14px"><button class="btn btn-primary" onclick="toast('📊 Report generated!','success')">🔍 View Report</button><button class="btn btn-danger" onclick="toast('📥 Downloading PDF...','success')">📥 Download PDF</button><button class="btn btn-secondary">Clear</button></div></div></div>
<div class="page" id="page-rep_target"><div class="ph-title" style="margin-bottom:18px">Target Collection &amp; CF</div><div class="rf"><div class="rf-grid"><div class="fg"><label>Branch</label><select><option>— All Branches —</option><option selected>Malolos</option></select></div><div class="fg"><label>Date From</label><input type="date" value="2026-04-27"></div><div class="fg"><label>Date To</label><input type="date" value="2026-04-27"></div></div><div style="display:flex;gap:8px;margin-top:14px"><button class="btn btn-primary" onclick="toast('📊 Report generated!','success')">🔍 View Report</button><button class="btn btn-danger" onclick="toast('📥 Downloading PDF...','success')">📥 Download PDF</button><button class="btn btn-secondary">Clear</button></div></div></div>
<div class="page" id="page-rep_col"><div class="ph-title" style="margin-bottom:18px">Collection Sheet</div><div class="rf"><div class="rf-grid"><div class="fg"><label>Branch</label><select><option>— All Branches —</option><option selected>Malolos</option></select></div><div class="fg"><label>Date From</label><input type="date" value="2026-04-27"></div><div class="fg"><label>Date To</label><input type="date" value="2026-04-27"></div></div><div style="display:flex;gap:8px;margin-top:14px"><button class="btn btn-primary" onclick="toast('📊 Report generated!','success')">🔍 View Report</button><button class="btn btn-danger" onclick="toast('📥 Downloading PDF...','success')">📥 Download PDF</button><button class="btn btn-secondary">Clear</button></div></div></div>
<div class="page" id="page-rep_trans"><div class="ph-title" style="margin-bottom:18px">Transaction Report</div><div class="rf"><div class="rf-grid"><div class="fg"><label>Date From</label><input type="date" value="2026-04-27"></div><div class="fg"><label>Date To</label><input type="date" value="2026-04-27"></div><div class="fg"><label>Branch</label><select><option>— All Branches —</option><option selected>Malolos</option></select></div><div class="fg"><label>Customer Type</label><select><option>— All —</option><option>SSS</option><option>GSIS</option></select></div><div class="fg"><label>Customer</label><input placeholder="Search customer..."></div><div class="fg"><label>Transaction No</label><input placeholder="Transaction number"></div><div class="fg"><label>Term From</label><input type="number" placeholder="e.g. 6"></div><div class="fg"><label>Term To</label><input type="number" placeholder="e.g. 12"></div><div class="fg"><label>Pension Type</label><select><option>— All —</option><option>Retirement</option><option>Surviving Spouse</option></select></div><div class="fg"><label>Marketing Type</label><select><option>— All —</option></select></div><div class="fg"><label>Transaction Type</label><select><option>— All —</option></select></div></div><label class="chk-row" style="margin-top:10px"><input type="checkbox"> Exclude Bonus Transactions</label><div style="display:flex;gap:8px;margin-top:14px"><button class="btn btn-primary" onclick="toast('📊 Report generated!','success')">🔍 View Report</button><button class="btn btn-danger" onclick="toast('📥 Downloading PDF...','success')">📥 Download PDF</button><button class="btn btn-secondary">Clear</button></div></div></div>
