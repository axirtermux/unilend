  <div class="ph"><div><div class="ph-title">Products</div><div class="ph-sub" id="prod-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('products')">📤 Export</button><button class="btn btn-primary" onclick="openM('m-product')">+ Create</button></div></div>
  <div class="fbar"><div class="srch"><span>🔍</span><input placeholder="Search product name..." oninput="search('products',this.value)"></div><select class="btn btn-secondary btn-sm" onchange="fStatus('products',this.value)"><option value="">All Types</option><option>Additional</option><option>Bonus</option><option>Extension</option><option>New</option><option>Renewal</option><option>BUY OUT NEW</option></select></div>
  <div class="tw"><table class="dt" id="tbl-products"><thead><tr><th></th><th onclick="sortT('products',0)">Name</th><th onclick="sortT('products',1)">Loan Type</th><th>Description</th><th>Actions</th></tr></thead><tbody id="tbody-products"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-products"></div><div class="pgn-btns" id="pgb-products"></div></div></div>
