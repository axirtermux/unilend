<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UniLend Portal — Manila Uni Capital Corp.</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0a1628;--navy2:#111f3a;--navy3:#172947;
  --blue:#1a56db;--blue2:#2563eb;--teal:#0ea5e9;
  --gold:#f59e0b;--emerald:#10b981;--rose:#f43f5e;
  --border:rgba(255,255,255,0.07);--card:rgba(255,255,255,0.04);--card2:rgba(255,255,255,0.08);
  --text:#f1f5f9;--text2:#cbd5e1;--text3:#94a3b8;
  --radius:14px;--sw:236px;--th:58px;--tr:all 0.25s cubic-bezier(.4,0,.2,1);
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:var(--navy);color:var(--text);overflow-x:hidden;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:4px;}

/* SIDEBAR */
.sidebar{position:fixed;top:0;left:0;width:var(--sw);height:100vh;background:linear-gradient(180deg,#0d1f3c,#07101e);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:200;box-shadow:4px 0 24px rgba(0,0,0,.5);}
.logo-area{padding:18px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0;}
.logo-icon{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--blue),var(--teal));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;color:#fff;flex-shrink:0;}
.logo-text{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;line-height:1.3;color:var(--text);}
.logo-sub{font-size:9.5px;color:var(--text3);}
.user-area{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0;}
.u-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--rose));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;flex-shrink:0;}
.u-name{font-size:12.5px;font-weight:600;}.u-role{font-size:10px;color:var(--text3);}
.nav-srch{padding:8px 12px;border-bottom:1px solid var(--border);flex-shrink:0;}
.nav-srch input{width:100%;background:var(--card);border:1px solid var(--border);border-radius:7px;padding:6px 10px;color:var(--text);font-size:12px;font-family:'DM Sans',sans-serif;outline:none;}
.nav-srch input:focus{border-color:rgba(37,99,235,.5);}
.nav-body{flex:1;overflow-y:auto;padding:6px 0 12px;}
.nav-lbl{font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;padding:10px 16px 3px;}
.ni{display:flex;align-items:center;gap:9px;padding:8px 14px;margin:1px 7px;border-radius:8px;cursor:pointer;transition:var(--tr);color:var(--text3);font-size:12.5px;font-weight:500;position:relative;user-select:none;}
.ni:hover{background:var(--card2);color:var(--text);}
.ni.active{background:linear-gradient(135deg,rgba(26,86,219,.22),rgba(14,165,233,.08));color:#60a5fa;border:1px solid rgba(26,86,219,.28);}
.ni.active::before{content:'';position:absolute;left:-7px;top:50%;transform:translateY(-50%);width:3px;height:55%;background:var(--blue2);border-radius:3px;}
.ni-ico{font-size:14px;width:16px;text-align:center;flex-shrink:0;}
.ni-badge{margin-left:auto;background:var(--rose);color:#fff;font-size:9px;font-weight:700;padding:2px 5px;border-radius:8px;}

/* TOPBAR */
.topbar{position:fixed;top:0;left:var(--sw);right:0;height:var(--th);background:rgba(10,22,40,.88);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 22px;z-index:190;gap:12px;}
.tb-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;flex:1;}
.tb-branch{display:flex;align-items:center;gap:6px;background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:5px 11px;font-size:12px;color:var(--text2);cursor:pointer;transition:var(--tr);}
.tb-branch:hover{background:var(--card);}
.tb-btn{width:34px;height:34px;border-radius:8px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;transition:var(--tr);color:var(--text2);position:relative;}
.tb-btn:hover{background:var(--card2);}
.notif-dot{width:7px;height:7px;background:var(--rose);border-radius:50%;position:absolute;top:-1px;right:-1px;border:2px solid var(--navy);}

/* MAIN */
.main{margin-left:var(--sw);padding-top:var(--th);min-height:100vh;}
.page{display:none;padding:24px 26px 50px;animation:pageIn .35s ease both;}
.page.active{display:block;}
@keyframes pageIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 15px;border-radius:8px;font-size:12.5px;font-weight:500;cursor:pointer;transition:var(--tr);border:none;font-family:'DM Sans',sans-serif;white-space:nowrap;}
.btn-primary{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;box-shadow:0 3px 12px rgba(26,86,219,.35);}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 5px 18px rgba(26,86,219,.5);}
.btn-success{background:linear-gradient(135deg,#059669,var(--emerald));color:#fff;box-shadow:0 3px 12px rgba(16,185,129,.3);}
.btn-success:hover{transform:translateY(-1px);}
.btn-danger{background:linear-gradient(135deg,#dc2626,var(--rose));color:#fff;}
.btn-danger:hover{transform:translateY(-1px);}
.btn-secondary{background:var(--card2);color:var(--text2);border:1px solid var(--border);}
.btn-secondary:hover{background:rgba(255,255,255,.1);color:var(--text);}
.btn-warning{background:linear-gradient(135deg,#d97706,var(--gold));color:#fff;}
.btn-sm{padding:5px 11px;font-size:11.5px;}
.btn-xs{padding:4px 9px;font-size:11px;}

/* PAGE HEADER */
.ph{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;gap:12px;}
.ph-title{font-family:'Syne',sans-serif;font-size:23px;font-weight:800;}
.ph-sub{font-size:12.5px;color:var(--text3);margin-top:3px;}
.ph-right{display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0;}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px;}
@media(max-width:1100px){.stats-grid{grid-template-columns:repeat(2,1fr);}}
.sc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;position:relative;overflow:hidden;cursor:pointer;transition:var(--tr);}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--radius) var(--radius) 0 0;}
.sc.teal::before{background:linear-gradient(90deg,var(--teal),#38bdf8);}
.sc.gold::before{background:linear-gradient(90deg,var(--gold),#fcd34d);}
.sc.green::before{background:linear-gradient(90deg,var(--emerald),#34d399);}
.sc.red::before{background:linear-gradient(90deg,var(--rose),#fb7185);}
.sc:hover{transform:translateY(-4px);box-shadow:0 18px 36px rgba(0,0,0,.35);border-color:rgba(255,255,255,.13);}
.sc-glow{position:absolute;top:-15px;right:-15px;width:80px;height:80px;border-radius:50%;opacity:.07;}
.sc.teal .sc-glow{background:var(--teal);}
.sc.gold .sc-glow{background:var(--gold);}
.sc.green .sc-glow{background:var(--emerald);}
.sc.red .sc-glow{background:var(--rose);}
.sc-ico{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:12px;}
.sc.teal .sc-ico{background:rgba(14,165,233,.15);}
.sc.gold .sc-ico{background:rgba(245,158,11,.15);}
.sc.green .sc-ico{background:rgba(16,185,129,.15);}
.sc.red .sc-ico{background:rgba(244,63,94,.15);}
.sc-lbl{font-size:10.5px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:5px;}
.sc-val{font-family:'Syne',sans-serif;font-size:25px;font-weight:800;line-height:1;}
.sc-chg{font-size:11px;color:var(--emerald);margin-top:5px;}
.sc-more{font-size:11px;color:var(--blue2);margin-top:10px;display:flex;align-items:center;gap:3px;font-weight:500;}

/* FILTER BAR */
.fbar{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.ftabs{display:flex;background:var(--card);border:1px solid var(--border);border-radius:9px;padding:3px;gap:2px;}
.ftab{padding:5px 13px;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer;transition:var(--tr);color:var(--text3);user-select:none;}
.ftab.active{background:var(--blue2);color:#fff;box-shadow:0 2px 8px rgba(37,99,235,.4);}
.ftab:hover:not(.active){background:var(--card2);color:var(--text);}
.srch{display:flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:7px 11px;}
.srch input{background:none;border:none;color:var(--text);font-size:12.5px;outline:none;font-family:'DM Sans',sans-serif;min-width:160px;}
.srch input::placeholder{color:var(--text3);}
.srch:focus-within{border-color:rgba(37,99,235,.4);}

/* TABLE */
.tw{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.dt{width:100%;border-collapse:collapse;}
.dt thead th{background:rgba(255,255,255,.04);padding:11px 14px;text-align:left;font-size:10.5px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);border-bottom:1px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none;transition:var(--tr);}
.dt thead th:hover{color:var(--text);background:rgba(255,255,255,.06);}
.dt thead th.asc::after{content:' ↑';}
.dt thead th.desc::after{content:' ↓';}
.dt tbody tr{border-bottom:1px solid rgba(255,255,255,.03);transition:background .15s;}
.dt tbody tr:hover{background:rgba(255,255,255,.03);}
.dt tbody tr:last-child{border-bottom:none;}
.dt td{padding:10px 14px;font-size:12.5px;color:var(--text2);vertical-align:middle;}
.dt td.bold{color:var(--text);font-weight:500;}
.dt td.mono{font-size:11.5px;font-family:monospace;color:var(--blue2);}
.dt td.green{color:var(--emerald);font-weight:600;}
.dt td.red-t{color:var(--rose);font-weight:600;}
.dt td.num{text-align:right;}
.empty-row td{text-align:center;padding:40px;color:var(--text3);font-style:italic;}

/* ACTION BTNS */
.ag{display:flex;gap:4px;align-items:center;}
.ab{width:28px;height:28px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;transition:var(--tr);border:none;background:transparent;}
.ab.edit{background:rgba(37,99,235,.12);color:var(--blue2);border:1px solid rgba(37,99,235,.2);}
.ab.edit:hover{background:rgba(37,99,235,.25);}
.ab.del{background:rgba(244,63,94,.1);color:var(--rose);border:1px solid rgba(244,63,94,.2);}
.ab.del:hover{background:rgba(244,63,94,.22);}
.ab.print{background:rgba(16,185,129,.1);color:var(--emerald);border:1px solid rgba(16,185,129,.2);}
.ab.print:hover{background:rgba(16,185,129,.22);}
.ab.view{background:rgba(245,158,11,.1);color:var(--gold);border:1px solid rgba(245,158,11,.2);}
.ab.view:hover{background:rgba(245,158,11,.22);}
.proc-btn{padding:5px 12px;border-radius:6px;font-size:11.5px;font-weight:600;background:linear-gradient(135deg,#059669,var(--emerald));color:#fff;cursor:pointer;border:none;transition:var(--tr);font-family:'DM Sans',sans-serif;}
.proc-btn:hover{transform:scale(1.04);}
.deny-btn{padding:5px 11px;border-radius:6px;font-size:11.5px;font-weight:600;background:rgba(244,63,94,.15);color:var(--rose);cursor:pointer;border:1px solid rgba(244,63,94,.2);transition:var(--tr);font-family:'DM Sans',sans-serif;}
.deny-btn:hover{background:rgba(244,63,94,.28);}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:10.5px;font-weight:700;white-space:nowrap;}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.b-active{background:rgba(16,185,129,.13);color:#34d399;}.b-active::before{background:#34d399;}
.b-pending{background:rgba(245,158,11,.13);color:#fbbf24;}.b-pending::before{background:#fbbf24;}
.b-problem{background:rgba(244,63,94,.13);color:#fb7185;}.b-problem::before{background:#fb7185;}
.b-paid{background:rgba(14,165,233,.13);color:#38bdf8;}.b-paid::before{background:#38bdf8;}
.b-dead{background:rgba(100,116,139,.13);color:#94a3b8;}.b-dead::before{background:#94a3b8;}
.b-release{background:rgba(139,92,246,.13);color:#a78bfa;}.b-release::before{background:#a78bfa;}
.b-credit{background:rgba(16,185,129,.13);color:#34d399;}.b-credit::before{background:#34d399;}
.b-debit{background:rgba(244,63,94,.13);color:#fb7185;}.b-debit::before{background:#fb7185;}
.b-approved{background:rgba(16,185,129,.13);color:#34d399;}.b-approved::before{background:#34d399;}
.b-denied{background:rgba(244,63,94,.13);color:#fb7185;}.b-denied::before{background:#fb7185;}

/* PAGINATION */
.pgn{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-top:1px solid var(--border);flex-wrap:wrap;gap:8px;}
.pgn-info{font-size:12px;color:var(--text3);}
.pgn-btns{display:flex;gap:3px;}
.pb{width:30px;height:30px;border-radius:7px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;color:var(--text2);transition:var(--tr);user-select:none;}
.pb.active{background:var(--blue2);border-color:var(--blue2);color:#fff;}
.pb:hover:not(.active):not(.dis){background:var(--card2);}
.pb.dis{opacity:.3;cursor:default;}
.pgn-size select{background:var(--card);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:3px 6px;font-size:11px;font-family:'DM Sans',sans-serif;outline:none;}

/* ══════════════════════════
   MODALS — OVERLAY + BASE
══════════════════════════ */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s;padding:16px;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:linear-gradient(145deg,#0f1f3a,#0b1628);border:1px solid rgba(255,255,255,.1);border-radius:18px;width:100%;max-height:90vh;overflow-y:auto;transform:scale(.94) translateY(16px);transition:transform .3s cubic-bezier(.34,1.56,.64,1),opacity .25s;opacity:0;box-shadow:0 30px 80px rgba(0,0,0,.7);}
.overlay.open .modal{transform:scale(1) translateY(0);opacity:1;}
.modal.sm{max-width:480px;}
.modal.md{max-width:620px;}
.modal.lg{max-width:820px;}
.modal.xl{max-width:1000px;}

/* Modal Header */
.mhd{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;border-bottom:1px solid var(--border);}
.mhd-left{display:flex;align-items:center;gap:10px;}
.mhd-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;}
.mhd-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;}
.mhd-sub{font-size:11px;color:var(--text3);margin-top:2px;}
.mc{width:30px;height:30px;border-radius:7px;background:var(--card2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--text2);transition:var(--tr);}
.mc:hover{background:rgba(244,63,94,.2);color:var(--rose);}

/* Modal Body */
.mbody{padding:20px 22px;}
.mft{padding:14px 22px 20px;display:flex;gap:8px;justify-content:flex-end;border-top:1px solid var(--border);}

/* Section inside modal */
.msec{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:16px;}
.msec-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.msec-title::before{content:'';width:3px;height:16px;background:var(--blue2);border-radius:3px;}

/* FORM CONTROLS */
.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:13px;}
.fg:last-child{margin-bottom:0;}
.fg label{font-size:10.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);}
.fg .req{color:var(--rose);}
.fg input,.fg select,.fg textarea{background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:var(--tr);width:100%;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:rgba(37,99,235,.5);background:rgba(37,99,235,.07);}
.fg input.readonly{opacity:.6;cursor:default;}
.fg select option{background:#0f1f3a;color:var(--text);}
.fg textarea{resize:vertical;min-height:80px;}
.fg .hint{font-size:10.5px;color:var(--text3);margin-top:3px;}
.fg .errmsg{font-size:11px;color:var(--rose);margin-top:2px;display:none;}
.fg.has-err .errmsg{display:block;}
.fg.has-err input,.fg.has-err select{border-color:rgba(244,63,94,.5)!important;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.fr4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.chk-row{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text2);cursor:pointer;padding:4px 0;}
.chk-row input{accent-color:var(--blue2);width:15px;height:15px;}
.rrow{display:flex;gap:18px;flex-wrap:wrap;}
.ri{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text2);cursor:pointer;}
.ri input{accent-color:var(--blue2);}

/* Avatar Upload Box */
.avatar-box{width:130px;height:130px;border-radius:14px;background:rgba(255,255,255,.05);border:2px dashed var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:var(--tr);flex-shrink:0;}
.avatar-box:hover{border-color:var(--blue2);background:rgba(37,99,235,.05);}
.avatar-box span{font-size:36px;margin-bottom:6px;}
.avatar-box p{font-size:10px;color:var(--text3);text-align:center;}
.avatar-with-img{position:relative;}
.avatar-with-img img{width:130px;height:130px;border-radius:14px;object-fit:cover;}
.avatar-edit-overlay{position:absolute;inset:0;border-radius:14px;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:.2s;cursor:pointer;}
.avatar-with-img:hover .avatar-edit-overlay{opacity:1;}

/* Inner sub-table for children/identifications etc */
.sub-table-wrap{border:1px solid var(--border);border-radius:9px;overflow:hidden;margin-top:8px;}
.sub-table-hd{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--border);}
.sub-table-title{font-size:12px;font-weight:700;color:var(--text);}
.sub-table{width:100%;border-collapse:collapse;}
.sub-table th{padding:8px 12px;font-size:10px;font-weight:700;letter-spacing:.7px;text-transform:uppercase;color:var(--text3);background:rgba(255,255,255,.03);border-bottom:1px solid var(--border);text-align:left;}
.sub-table td{padding:8px 12px;font-size:12px;color:var(--text2);border-bottom:1px solid rgba(255,255,255,.03);}
.sub-table tr:last-child td{border-bottom:none;}
.sub-empty{padding:20px;text-align:center;color:var(--text3);font-size:12px;font-style:italic;}

/* Amortization schedule table */
.sched-table{width:100%;border-collapse:collapse;}
.sched-table th{padding:8px 10px;font-size:10px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text3);background:rgba(255,255,255,.04);border-bottom:1px solid var(--border);text-align:left;}
.sched-table td{padding:7px 10px;font-size:11.5px;color:var(--text2);border-bottom:1px solid rgba(255,255,255,.03);}

/* REPORT FORM */
.rf{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:22px;margin-bottom:18px;}
.rf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:12px;}

/* CHARTS */
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:22px;}
@media(max-width:900px){.chart-grid{grid-template-columns:1fr;}}
.cc{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;}
.cc-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;}
.cc-title{font-family:'Syne',sans-serif;font-size:13.5px;font-weight:700;}
.cc-sub{font-size:11px;color:var(--text3);margin-top:2px;}
.bar-wrap{height:140px;display:flex;align-items:flex-end;gap:5px;}
.bar{flex:1;border-radius:5px 5px 0 0;cursor:pointer;transition:var(--tr);position:relative;}
.bar:hover{filter:brightness(1.3);}
.bar-tip{position:absolute;bottom:calc(100% + 4px);left:50%;transform:translateX(-50%);background:var(--navy2);border:1px solid var(--border);border-radius:5px;padding:3px 7px;font-size:10px;white-space:nowrap;pointer-events:none;opacity:0;transition:.2s;}
.bar:hover .bar-tip{opacity:1;}
.bar-lbl{position:absolute;bottom:-18px;left:50%;transform:translateX(-50%);font-size:9px;color:var(--text3);white-space:nowrap;}
.donut-wrap{display:flex;align-items:center;gap:18px;}
.donut{position:relative;width:110px;height:110px;flex-shrink:0;}
.donut svg{transform:rotate(-90deg);}
.donut-ctr{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;}
.donut-val{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;}
.donut-lbl2{font-size:10px;color:var(--text3);}
.legend{flex:1;}
.li{display:flex;align-items:center;gap:7px;margin-bottom:8px;font-size:12px;}
.li-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0;}
.li-name{color:var(--text2);flex:1;}
.li-pct{color:var(--text3);font-weight:500;}

/* ACTIVITY */
.act-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;}
.act-item{display:flex;gap:11px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.03);}
.act-item:last-child{border:none;}
.act-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;}
.act-text{font-size:12.5px;color:var(--text2);line-height:1.5;}
.act-time{font-size:10.5px;color:var(--text3);margin-top:1px;}
.qa-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;}

/* TOAST */
.toast-wrap{position:fixed;bottom:22px;right:22px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.toast{background:linear-gradient(135deg,var(--navy2),var(--navy3));border:1px solid rgba(255,255,255,.1);border-radius:11px;padding:12px 18px;display:flex;align-items:center;gap:10px;font-size:12.5px;box-shadow:0 16px 40px rgba(0,0,0,.5);transform:translateX(120%);transition:transform .35s cubic-bezier(.34,1.56,.64,1);pointer-events:all;}
.toast.show{transform:translateX(0);}
.toast.success{border-color:rgba(16,185,129,.3);}
.toast.error{border-color:rgba(244,63,94,.3);}
.toast.warn{border-color:rgba(245,158,11,.3);}

/* CONFIRM */
.confirm-box{background:linear-gradient(135deg,#0f1f3a,#0b1628);border:1px solid rgba(244,63,94,.25);border-radius:14px;padding:24px;width:320px;text-align:center;}
.confirm-ico{font-size:36px;margin-bottom:10px;}
.confirm-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:6px;}
.confirm-msg{font-size:13px;color:var(--text3);margin-bottom:18px;}
.confirm-btns{display:flex;gap:8px;justify-content:center;}

/* LIVE DOT */
.ldot{width:6px;height:6px;background:var(--emerald);border-radius:50%;display:inline-block;animation:pulse 2s infinite;margin-right:4px;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.divider{height:1px;background:var(--border);margin:14px 0;}
.sec-hd{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text);margin-bottom:10px;}
.info-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:14px;}
.info-item{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:9px;padding:10px 12px;}
.info-lbl{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:3px;}
.info-val{font-size:13px;font-weight:500;color:var(--text);}
.meta-bar{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:9px;padding:10px 14px;font-size:11px;color:var(--text3);margin-top:14px;}
</style>
</head>
<body>

<!-- SIDEBAR -->
<nav class="sidebar">
  <div class="logo-area">
    <div class="logo-icon">UC</div>
    <div><div class="logo-text">Manila Uni Capital</div><div class="logo-sub">Corp. Portal v3.7.10</div></div>
  </div>
  <div class="user-area">
    <div class="u-av">E</div>
    <div><div class="u-name">Eleazar</div><div class="u-role">Administrator · Malolos</div></div>
  </div>
  <div class="nav-srch"><input placeholder="🔍 Search menu..." oninput="searchNav(this.value)"></div>
  <div class="nav-body">
    <div class="nav-lbl">Main</div>
    <div class="ni active" data-page="dashboard" onclick="nav(this)"><span class="ni-ico">📊</span>Dashboard</div>
    <div class="ni" data-page="account" onclick="nav(this)"><span class="ni-ico">👤</span>Account Info</div>
    <div class="ni" data-page="loanproc" onclick="nav(this)"><span class="ni-ico">📋</span>Loan Processing<span class="ni-badge">28k</span></div>
    <div class="ni" data-page="loanapproval" onclick="nav(this)"><span class="ni-ico">✅</span>Loan Approval<span class="ni-badge" id="pending-badge">34</span></div>
    <div class="ni" data-page="vouchers" onclick="nav(this)"><span class="ni-ico">🧾</span>Vouchers</div>
    <div class="ni" data-page="collections" onclick="nav(this)"><span class="ni-ico">💰</span>Collections</div>
    <div class="ni" data-page="changefunds" onclick="nav(this)"><span class="ni-ico">🔄</span>Change Funds</div>
    <div class="nav-lbl">Reports</div>
    <div class="ni" data-page="rep_cf" onclick="nav(this)"><span class="ni-ico">📄</span>Change Fund Register</div>
    <div class="ni" data-page="rep_check" onclick="nav(this)"><span class="ni-ico">📄</span>Check Register</div>
    <div class="ni" data-page="rep_target" onclick="nav(this)"><span class="ni-ico">📄</span>Target Collection &amp; CF</div>
    <div class="ni" data-page="rep_col" onclick="nav(this)"><span class="ni-ico">📄</span>Collection Sheet</div>
    <div class="ni" data-page="rep_trans" onclick="nav(this)"><span class="ni-ico">📄</span>Transaction Report</div>
    <div class="ni" data-page="rep_udi" onclick="nav(this)"><span class="ni-ico">📄</span>UDI Report</div>
    <div class="nav-lbl">Setup</div>
    <div class="ni" data-page="banks" onclick="nav(this)"><span class="ni-ico">🏦</span>Banks</div>
    <div class="ni" data-page="bankaccounts" onclick="nav(this)"><span class="ni-ico">💳</span>Bank Accounts</div>
    <div class="ni" data-page="products" onclick="nav(this)"><span class="ni-ico">📦</span>Products</div>
    <div class="ni" data-page="agents" onclick="nav(this)"><span class="ni-ico">🤝</span>Agents</div>
    <div class="ni" data-page="addresses" onclick="nav(this)"><span class="ni-ico">📍</span>Addresses</div>
    <div class="ni" data-page="lookups" onclick="nav(this)"><span class="ni-ico">🔎</span>LookUps</div>
  </div>
</nav>

<!-- TOPBAR -->
<header class="topbar">
  <div class="tb-title" id="tb-title">Dashboard</div>
  <div class="tb-branch" onclick="toast('🏢 Branch switching coming soon','warn')">🏢 Malolos ▾</div>
  <div class="tb-btn" onclick="toast('🔔 34 pending loan approvals','warn')" title="Notifications" style="position:relative">🔔<span class="notif-dot"></span></div>
  <div class="tb-btn" onclick="toast('🔍 Use page search bars for records','warn')" title="Global Search">🔍</div>
  <div class="tb-btn" onclick="toast('⚙️ Settings — coming soon','warn')" title="Settings">⚙️</div>
  <div class="tb-btn" onclick="confirmDlg('Logout','Are you sure you want to logout?',()=>toast('👋 Logged out','success'))" title="Logout" style="color:var(--rose)">🚪</div>
</header>

<!-- MAIN -->
<main class="main">

<!-- ══ DASHBOARD ══ -->
<div class="page active" id="page-dashboard">
  <div class="ph">
    <div><div class="ph-title">Good day, Eleazar 👋</div><div class="ph-sub"><span class="ldot"></span>Live · Malolos Branch · <span id="dash-date"></span></div></div>
    <div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('accounts')">📤 Export</button><button class="btn btn-primary" onclick="toast('📊 Report generated!','success')">Generate Report</button></div>
  </div>
  <div class="stats-grid">
    <div class="sc teal" onclick="nav(document.querySelector('[data-page=account]'))"><div class="sc-glow"></div><div class="sc-ico">👥</div><div class="sc-lbl">Total Pensioners</div><div class="sc-val" id="cnt-pensioners">0</div><div class="sc-chg">↑ +12 this month</div><div class="sc-more">View accounts →</div></div>
    <div class="sc gold" onclick="nav(document.querySelector('[data-page=loanapproval]'))"><div class="sc-glow"></div><div class="sc-ico">⏳</div><div class="sc-lbl">Pending Approvals</div><div class="sc-val" id="cnt-pending">0</div><div class="sc-chg">Awaiting review</div><div class="sc-more">View approvals →</div></div>
    <div class="sc green" onclick="nav(document.querySelector('[data-page=loanproc]'))"><div class="sc-glow"></div><div class="sc-ico">💵</div><div class="sc-lbl">Loans (Approved)</div><div class="sc-val" id="cnt-loans">₱0</div><div class="sc-chg">↑ +₱2.1M vs last month</div><div class="sc-more">View processing →</div></div>
    <div class="sc red" onclick="nav(document.querySelector('[data-page=collections]'))"><div class="sc-glow"></div><div class="sc-ico">💳</div><div class="sc-lbl">Receivables</div><div class="sc-val" id="cnt-recv">₱0</div><div class="sc-chg">↓ -₱341K collected</div><div class="sc-more">View collections →</div></div>
  </div>
  <div class="chart-grid">
    <div class="cc"><div class="cc-hd"><div><div class="cc-title">Monthly Loan Disbursements</div><div class="cc-sub">2025 · ₱ in millions</div></div></div><div class="bar-wrap" id="dash-bars"></div></div>
    <div class="cc"><div class="cc-hd"><div><div class="cc-title">Loan Type Distribution</div><div class="cc-sub">By product category</div></div></div>
      <div class="donut-wrap">
        <div class="donut"><svg viewBox="0 0 110 110" width="110" height="110"><circle cx="55" cy="55" r="40" fill="none" stroke="rgba(255,255,255,.05)" stroke-width="16"/><circle cx="55" cy="55" r="40" fill="none" stroke="#1a56db" stroke-width="16" stroke-dasharray="100 152" stroke-linecap="round"/><circle cx="55" cy="55" r="40" fill="none" stroke="#10b981" stroke-width="16" stroke-dasharray="58 194" stroke-dashoffset="-100" stroke-linecap="round"/><circle cx="55" cy="55" r="40" fill="none" stroke="#f59e0b" stroke-width="16" stroke-dasharray="36 216" stroke-dashoffset="-158" stroke-linecap="round"/><circle cx="55" cy="55" r="40" fill="none" stroke="#f43f5e" stroke-width="16" stroke-dasharray="18 234" stroke-dashoffset="-194" stroke-linecap="round"/></svg><div class="donut-ctr"><div class="donut-val">65</div><div class="donut-lbl2">Products</div></div></div>
        <div class="legend"><div class="li"><div class="li-dot" style="background:#1a56db"></div><div class="li-name">Extension</div><div class="li-pct">40%</div></div><div class="li"><div class="li-dot" style="background:#10b981"></div><div class="li-name">Additional</div><div class="li-pct">23%</div></div><div class="li"><div class="li-dot" style="background:#f59e0b"></div><div class="li-name">Buy-Out</div><div class="li-pct">14%</div></div><div class="li"><div class="li-dot" style="background:#f43f5e"></div><div class="li-name">Bonus/Other</div><div class="li-pct">23%</div></div></div>
      </div>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 310px;gap:16px">
    <div class="act-card"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px"><div class="sec-hd" style="margin:0">Recent Activity</div><span style="font-size:11px;color:var(--text3)">Today</span></div><div id="activity-feed"></div></div>
    <div class="qa-card"><div class="sec-hd">Quick Actions</div><div style="display:flex;flex-direction:column;gap:8px">
      <button class="btn btn-primary" onclick="nav(document.querySelector('[data-page=account]'));setTimeout(()=>openM('m-account'),400)">👤 New Account</button>
      <button class="btn btn-success" onclick="nav(document.querySelector('[data-page=vouchers]'));setTimeout(()=>openM('m-voucher'),400)">🧾 New Voucher</button>
      <button class="btn btn-secondary" onclick="nav(document.querySelector('[data-page=loanproc]'));setTimeout(()=>openM('m-loan'),400)">📋 New Loan</button>
      <button class="btn btn-secondary" onclick="nav(document.querySelector('[data-page=collections]'));setTimeout(()=>openM('m-collection'),400)">💰 Record Collection</button>
      <button class="btn btn-secondary" onclick="nav(document.querySelector('[data-page=rep_trans]'))">📊 Transaction Report</button>
    </div><div class="divider"></div><div class="sec-hd">Branch Summary</div><div id="branch-summary"></div></div>
  </div>
</div>

<!-- ══ ACCOUNT INFO ══ -->
<div class="page" id="page-account">
  <div class="ph"><div><div class="ph-title">Account Info</div><div class="ph-sub" id="acct-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('accounts')">📤 Export</button><button class="btn btn-primary" onclick="openM('m-account')">+ Create</button></div></div>
  <div class="fbar">
    <div class="ftabs"><div class="ftab" onclick="fStatus('accounts','')">All</div><div class="ftab active" onclick="fStatus('accounts','Active')">Active</div><div class="ftab" onclick="fStatus('accounts','Problem')">Problem</div><div class="ftab" onclick="fStatus('accounts','Fully Paid')">Fully Paid</div><div class="ftab" onclick="fStatus('accounts','Archived')">Archived</div></div>
    <div class="srch"><span>🔍</span><input placeholder="Search name, pension #, bank..." oninput="search('accounts',this.value)"></div>
  </div>
  <div class="tw"><table class="dt" id="tbl-accounts"><thead><tr><th></th><th onclick="sortT('accounts',0)">Pension Number</th><th onclick="sortT('accounts',1)">Full Name</th><th onclick="sortT('accounts',2)">Provider</th><th onclick="sortT('accounts',3)">Pension Type</th><th onclick="sortT('accounts',4)" class="num">Pension</th><th onclick="sortT('accounts',5)">Bank</th><th onclick="sortT('accounts',6)">Status</th><th>Actions</th></tr></thead><tbody id="tbody-accounts"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-accounts"></div><div class="pgn-btns" id="pgb-accounts"></div><div class="pgn-size">Show <select onchange="chgPS('accounts',this.value)"><option>15</option><option>30</option><option>50</option></select></div></div></div>
</div>

<!-- ══ LOAN PROCESSING ══ -->
<div class="page" id="page-loanproc">
  <div class="ph"><div><div class="ph-title">Loan Processing</div><div class="ph-sub" id="lp-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('loans')">📤 Export</button><button class="btn btn-primary" onclick="openM('m-loan')">+ Create</button></div></div>
  <div class="fbar">
    <div class="ftabs"><div class="ftab" onclick="fStatus('loans','')">All</div><div class="ftab active" onclick="fStatus('loans','Active')">Active</div><div class="ftab" onclick="fStatus('loans','Archived')">Archived</div></div>
    <div class="srch"><span>🔍</span><input placeholder="Search reference, customer..." oninput="search('loans',this.value)"></div>
  </div>
  <div class="tw"><table class="dt" id="tbl-loans"><thead><tr><th></th><th onclick="sortT('loans',0)">Reference</th><th onclick="sortT('loans',1)">Loan Date</th><th onclick="sortT('loans',2)">Customer Name</th><th class="num">Amortization</th><th class="num">#</th><th class="num">Principal</th><th class="num">Proc.</th><th class="num">Not.</th><th class="num">Ins.</th><th class="num">Interest</th><th class="num">Cash Out</th><th>Actions</th></tr></thead><tbody id="tbody-loans"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-loans"></div><div class="pgn-btns" id="pgb-loans"></div><div class="pgn-size">Show <select onchange="chgPS('loans',this.value)"><option>15</option><option>30</option><option>50</option></select></div></div></div>
</div>

<!-- ══ LOAN APPROVAL ══ -->
<div class="page" id="page-loanapproval">
  <div class="ph"><div><div class="ph-title">Loan Approval</div><div class="ph-sub" id="la-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('approvals')">📤 Export</button></div></div>
  <div class="fbar">
    <div class="ftabs"><div class="ftab active" onclick="fStatus('approvals','Pending')">Pending</div><div class="ftab" onclick="fStatus('approvals','Approved')">Approved</div><div class="ftab" onclick="fStatus('approvals','Denied')">Denied</div><div class="ftab" onclick="fStatus('approvals','')">All</div></div>
    <div class="srch"><span>🔍</span><input placeholder="Search reference, customer..." oninput="search('approvals',this.value)"></div>
  </div>
  <div class="tw"><table class="dt" id="tbl-approvals"><thead><tr><th onclick="sortT('approvals',0)">Reference</th><th onclick="sortT('approvals',1)">Loan Date</th><th onclick="sortT('approvals',2)">Customer</th><th class="num">Amortization</th><th class="num">#</th><th class="num">Principal</th><th>Status</th><th>Actions</th></tr></thead><tbody id="tbody-approvals"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-approvals"></div><div class="pgn-btns" id="pgb-approvals"></div><div class="pgn-size">Show <select onchange="chgPS('approvals',this.value)"><option>15</option><option>30</option><option>50</option></select></div></div></div>
</div>

<!-- ══ VOUCHERS ══ -->
<div class="page" id="page-vouchers">
  <div class="ph"><div><div class="ph-title">Vouchers</div><div class="ph-sub" id="v-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('vouchers')">📤 Export</button><button class="btn btn-secondary" onclick="toast('🔗 Link to Loan','warn')">🔗 Loan...</button><button class="btn btn-primary" onclick="openM('m-voucher')">+ Create</button></div></div>
  <div class="fbar">
    <div class="ftabs"><div class="ftab active" onclick="fStatus('vouchers','Active')">Active</div><div class="ftab" onclick="fStatus('vouchers','Archived')">Archived</div><div class="ftab" onclick="fStatus('vouchers','')">All</div></div>
    <div class="srch"><span>🔍</span><input placeholder="Search voucher #, payee..." oninput="search('vouchers',this.value)"></div>
  </div>
  <div class="tw"><table class="dt" id="tbl-vouchers"><thead><tr><th></th><th onclick="sortT('vouchers',0)">Voucher #</th><th onclick="sortT('vouchers',1)">Date</th><th onclick="sortT('vouchers',2)">Payee</th><th onclick="sortT('vouchers',3)">Bank Account</th><th class="num">Amount</th><th>Status</th><th>Actions</th></tr></thead><tbody id="tbody-vouchers"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-vouchers"></div><div class="pgn-btns" id="pgb-vouchers"></div><div class="pgn-size">Show <select onchange="chgPS('vouchers',this.value)"><option>15</option><option>30</option><option>50</option></select></div></div></div>
</div>

<!-- ══ COLLECTIONS ══ -->
<div class="page" id="page-collections">
  <div class="ph"><div><div class="ph-title">Collections</div><div class="ph-sub" id="col-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('collections')">📤 Export</button><button class="btn btn-primary" onclick="openM('m-collection')">+ Create</button></div></div>
  <div class="fbar">
    <div class="ftabs"><div class="ftab active" onclick="fStatus('collections','Active')">Active</div><div class="ftab" onclick="fStatus('collections','Archived')">Archived</div><div class="ftab" onclick="fStatus('collections','')">All</div></div>
    <div class="srch"><span>🔍</span><input placeholder="Search control #, customer..." oninput="search('collections',this.value)"></div>
  </div>
  <div class="tw"><table class="dt" id="tbl-collections"><thead><tr><th></th><th onclick="sortT('collections',0)">Control No.</th><th onclick="sortT('collections',1)">Date</th><th onclick="sortT('collections',2)">Customer</th><th class="num">Amount</th><th class="num">Bonus</th><th>Remarks</th><th>Actions</th></tr></thead><tbody id="tbody-collections"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-collections"></div><div class="pgn-btns" id="pgb-collections"></div><div class="pgn-size">Show <select onchange="chgPS('collections',this.value)"><option>15</option><option>30</option><option>50</option></select></div></div></div>
</div>

<!-- ══ CHANGE FUNDS ══ -->
<div class="page" id="page-changefunds">
  <div class="ph"><div><div class="ph-title">Change Funds</div><div class="ph-sub" id="cf-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('changefunds')">📤 Export</button><button class="btn btn-primary" onclick="openM('m-changefund')">+ Create</button></div></div>
  <div class="fbar">
    <div class="ftabs"><div class="ftab active" onclick="fStatus('changefunds','')">All</div><div class="ftab" onclick="fStatus('changefunds','Credit')">Credit</div><div class="ftab" onclick="fStatus('changefunds','Debit')">Debit</div></div>
    <div class="srch"><span>🔍</span><input placeholder="Search CF #, customer..." oninput="search('changefunds',this.value)"></div>
  </div>
  <div class="tw"><table class="dt" id="tbl-changefunds"><thead><tr><th></th><th onclick="sortT('changefunds',0)">CF No.</th><th onclick="sortT('changefunds',1)">Entry Date</th><th onclick="sortT('changefunds',2)">Type</th><th class="num">Amount</th><th>Customer Name</th><th>Remarks</th><th>Branch</th><th>Actions</th></tr></thead><tbody id="tbody-changefunds"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-changefunds"></div><div class="pgn-btns" id="pgb-changefunds"></div><div class="pgn-size">Show <select onchange="chgPS('changefunds',this.value)"><option>15</option><option>30</option><option>50</option></select></div></div></div>
</div>

