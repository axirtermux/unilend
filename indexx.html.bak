<div class="page" id="page-banks">
  <div class="ph"><div><div class="ph-title">Banks</div><div class="ph-sub" id="banks-sub">Loading...</div></div><div class="ph-right"><button class="btn btn-secondary" onclick="exportCSV('banks')">📤 Export</button><button class="btn btn-primary" onclick="openM('m-bank')">+ Create</button></div></div>
  <div class="fbar"><div class="srch"><span>🔍</span><input placeholder="Search bank name..." oninput="search('banks',this.value)"></div></div>
  <div class="tw"><table class="dt" id="tbl-banks"><thead><tr><th></th><th onclick="sortT('banks',0)">Bank Name</th><th>Address</th><th>Contact Person</th><th>Position</th><th>Contact No.</th><th>Actions</th></tr></thead><tbody id="tbody-banks"></tbody></table><div class="pgn"><div class="pgn-info" id="pgi-banks"></div><div class="pgn-btns" id="pgb-banks"></div></div></div>
