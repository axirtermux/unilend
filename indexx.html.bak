<!-- ══════════════════════════════════════════════
     MODALS
══════════════════════════════════════════════ -->

<!-- ① ACCOUNT INFO / CUSTOMER INFO (Images 1–6) -->
<div class="overlay" id="m-account">
 <div class="modal xl">
  <div class="mhd">
   <div class="mhd-left"><div class="mhd-icon" style="background:rgba(37,99,235,.15)">👤</div><div><div class="mhd-title" id="m-account-title">Customer Info</div><div class="mhd-sub">Create new pensioner account</div></div></div>
   <div class="mc" onclick="closeM('m-account')">✕</div>
  </div>
  <div class="mbody">
   <!-- Customer Info Section -->
   <div class="msec">
    <div class="msec-title">Customer Info</div>
    <div style="display:flex;gap:20px;align-items:flex-start">
     <div style="flex:1">
      <div class="fr3"><div class="fg"><label>Prefix</label><select id="ai-prefix"><option></option><option>Mr.</option><option>Mrs.</option><option>Ms.</option><option>Dr.</option><option>Engr.</option></select></div><div class="fg" style="grid-column:span 2"><label>First Name <span class="req">*</span></label><input id="ai-fname" placeholder="First Name"><div class="errmsg">Required</div></div></div>
      <div class="fr"><div class="fg"><label>Middle Name</label><input id="ai-mname" placeholder="Middle Name"></div><div class="fg"><label>Last Name <span class="req">*</span></label><input id="ai-lname" placeholder="Last Name"><div class="errmsg">Required</div></div></div>
      <div class="fr"><div class="fg"><label>Suffix</label><input id="ai-suffix" placeholder="e.g. Jr., Sr., III"></div><div class="fg"><label>Nick Name</label><input id="ai-nick" placeholder="Nick Name"></div></div>
      <div class="fr"><div class="fg"><label>Reference Number</label><div style="display:flex;gap:6px"><select id="ai-reftype" style="width:130px;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:8px;padding:9px 10px;color:var(--text);font-family:inherit;outline:none;"><option>Automatic</option><option>Manual</option></select><input id="ai-refno" class="readonly" value="0000000000" readonly style="flex:1"></div></div><div class="fg"><label>Registration Date</label><input type="datetime-local" id="ai-regdate"></div></div>
      <label class="chk-row"><input type="checkbox" id="ai-active" checked> Is Active</label>
      <div class="fg" style="margin-top:10px"><label>Remarks</label><textarea id="ai-remarks" placeholder="Remarks..." style="min-height:60px"></textarea></div>
     </div>
     <div>
      <div class="avatar-box" onclick="toast('📷 Photo upload feature','warn')" style="margin-top:0">
       <span>👤</span><p>Click on the<br>image to edit</p>
      </div>
     </div>
    </div>
   </div>
   <!-- Personal Info Section -->
   <div class="msec">
    <div class="msec-title">Personal Info</div>
    <div class="fr"><div class="fg"><label>Sex</label><select id="ai-sex"><option>Male</option><option>Female</option></select></div><div class="fg"><label>Contact No.</label><input id="ai-contact" placeholder="Contact No."></div></div>
    <div class="fr"><div class="fg"><label>Birth Date</label><input type="date" id="ai-bdate"></div><div class="fg"><label>Email</label><input type="email" id="ai-email" placeholder="Email address"></div></div>
    <div class="fg"><label>Civil Status</label><select id="ai-civil" style="max-width:300px"><option>Single</option><option>Married</option><option>Widowed</option><option>Separated</option></select></div>
   </div>
   <!-- Family Section -->
   <div class="msec">
    <div class="msec-title">Family</div>
    <div class="fr">
     <div>
      <div class="fg"><label>Father</label><div style="display:flex;gap:6px"><input id="ai-father" placeholder="Father" style="flex:1"><button class="btn btn-secondary btn-xs" onclick="toast('➕ Add father record','warn')">+ Add</button></div></div>
      <div class="fg"><label>Mother</label><div style="display:flex;gap:6px"><input id="ai-mother" placeholder="Mother" style="flex:1"><button class="btn btn-secondary btn-xs" onclick="toast('➕ Add mother record','warn')">+ Add</button></div></div>
      <div class="fg"><label>Spouse</label><div style="display:flex;gap:6px"><input id="ai-spouse" placeholder="Spouse" style="flex:1"><button class="btn btn-secondary btn-xs" onclick="toast('➕ Add spouse record','warn')">+ Add</button></div></div>
     </div>
     <div>
      <div class="fg"><label>Marriage Date</label><input type="date" id="ai-marriage"></div>
      <div class="fg"><label>Death Date</label><input type="date" id="ai-death"></div>
     </div>
    </div>
    <!-- Children sub-table -->
    <div class="sub-table-wrap" style="margin-top:10px">
     <div class="sub-table-hd"><div class="sub-table-title">Children</div><button class="btn btn-xs btn-primary" onclick="addChild()">+ Add</button></div>
     <table class="sub-table" id="children-table"><thead><tr><th>First Name</th><th>Last Name</th><th>Sex</th><th>Birth Date</th><th>Age</th><th>Contact No.</th><th></th></tr></thead><tbody id="children-body"><tr><td colspan="7" class="sub-empty">No children added</td></tr></tbody></table>
    </div>
   </div>
   <!-- Addresses Section -->
   <div class="msec">
    <div class="msec-title">Addresses</div>
    <div class="sub-table-wrap">
     <div class="sub-table-hd"><div class="sub-table-title">Address List</div><button class="btn btn-xs btn-primary" onclick="addAddress_ai()">+ Add</button></div>
     <table class="sub-table"><thead><tr><th>Address</th><th>Address Type</th><th>Tenure</th><th>Landmarks</th><th>Remarks</th><th></th></tr></thead><tbody id="ai-addr-body"><tr><td colspan="6" class="sub-empty">No addresses added</td></tr></tbody></table>
    </div>
   </div>
   <!-- Other Info -->
   <div class="msec">
    <div class="msec-title">Other Info</div>
    <div class="fr"><div class="fg"><label>Nationality</label><select id="ai-nationality"><option></option><option>Filipino</option><option>Chinese</option><option>American</option><option>Other</option></select></div><div class="fg"><label>Source of Income</label><input id="ai-income" placeholder="Source of Income"></div></div>
   </div>
   <!-- Pension Info -->
   <div class="msec">
    <div class="msec-title">Pension Info</div>
    <div class="fr">
     <div>
      <div class="fg"><label>Provider <span class="req">*</span></label><select id="ai-provider"><option></option><option>SSS</option><option>GSIS</option><option>PVAO</option></select></div>
      <div class="fg"><label>Pension Type <span class="req">*</span></label><select id="ai-ptype"><option></option><option>Retirement</option><option>Surviving Spouse of Dead Member</option><option>Disability</option><option>Death</option></select></div>
      <div class="fg"><label>Pension Number <span class="req">*</span></label><input id="ai-pnum" placeholder="Pension Number"></div>
      <div class="fg"><label>Nature of Sickness</label><input id="ai-sickness" placeholder="Nature of Sickness"></div>
      <div class="fg"><label>Coverage</label><div style="display:flex;gap:8px"><input type="date" id="ai-cov1" style="flex:1"><input type="date" id="ai-cov2" style="flex:1"></div></div>
     </div>
     <div>
      <div class="fg"><label>Amount</label><input type="number" id="ai-pamount" placeholder="0.00" step="0.01" value="0.00"></div>
      <div class="fg"><label>Withdrawable</label><input type="number" id="ai-withdraw" placeholder="0.00" step="0.01" value="0.00"></div>
      <div class="fg"><label>Withdraw Day</label><input type="number" id="ai-wday" placeholder="0" value="0"></div>
     </div>
    </div>
   </div>
   <!-- Bank Info -->
   <div class="msec">
    <div class="msec-title">Bank Info</div>
    <div class="fr">
     <div>
      <div class="fg"><label>Bank</label><input id="ai-bank" placeholder="Bank Name"></div>
      <div class="fg"><label>Bank Location</label><input id="ai-bankloc" placeholder="Bank Location"></div>
      <div class="fg"><label>Account Type</label><select id="ai-accttype"><option>ATM</option><option>Savings</option><option>Checking</option><option>Passbook</option></select></div>
      <div class="fg"><label>Account No.</label><input id="ai-acctno" placeholder="Account Number"></div>
     </div>
     <div>
      <div class="fg"><label>Card No.</label><input id="ai-cardno" placeholder="Card Number"></div>
      <div class="fg"><label>PIN</label><input type="password" id="ai-pin" placeholder="••••••••••••"></div>
     </div>
    </div>
   </div>
   <!-- Other Info (Pension Status) -->
   <div class="msec">
    <div class="msec-title">Other Info</div>
    <div class="fr">
     <div>
      <div class="fg"><label>Status</label><select id="ai-pstatus"><option></option><option>Active</option><option>Problem</option><option>Fully Paid</option><option>For Release</option><option>Dead Account</option></select></div>
      <div class="fg"><label>Custodian</label><input id="ai-custodian" value="Malolos"></div>
      <div class="fg"><label>Remarks</label><textarea id="ai-otherremarks" placeholder="Remarks..."></textarea></div>
     </div>
     <div>
      <div class="fg"><label>Marketing Group</label><select id="ai-mktgrp"><option></option><option>Group A</option><option>Group B</option></select></div>
      <div class="fg"><label>Marketing Type</label><select id="ai-mkttype"><option></option><option>Walk-in</option><option>Agent</option><option>Online</option></select></div>
     </div>
    </div>
   </div>
   <!-- Identification -->
   <div class="msec">
    <div class="msec-title">Identification</div>
    <div class="sub-table-wrap">
     <div class="sub-table-hd"><div class="sub-table-title">ID Documents</div><button class="btn btn-xs btn-primary" onclick="addID()">+ Add</button></div>
     <table class="sub-table"><thead><tr><th>Type of Identification</th><th>ID Number</th><th>Expiry</th><th></th></tr></thead><tbody id="ai-id-body"><tr><td colspan="4" class="sub-empty">No IDs added</td></tr></tbody></table>
    </div>
   </div>
   <!-- Documents -->
   <div class="msec">
    <div class="msec-title">Documents</div>
    <div class="sub-table-wrap">
     <div class="sub-table-hd"><div class="sub-table-title">Attached Documents</div><button class="btn btn-xs btn-primary" onclick="addDoc()">+ Add</button></div>
     <table class="sub-table"><thead><tr><th>Type of Document</th><th></th></tr></thead><tbody id="ai-doc-body"><tr><td colspan="2" class="sub-empty">No documents added</td></tr></tbody></table>
    </div>
   </div>
   <div class="meta-bar"><span>Created: <span id="ai-created">—</span></span><span>Updated: <span id="ai-updated">—</span></span></div>
  </div>
  <div class="mft">
   <button class="btn btn-secondary" onclick="closeM('m-account')">✕ Cancel</button>
   <button class="btn btn-primary" onclick="saveAccount()">💾 Save Account</button>
  </div>
 </div>
</div>

<!-- ② LOAN PROCESSING CREATE (Images 7–8) -->
<div class="overlay" id="m-loan">
 <div class="modal xl">
  <div class="mhd">
   <div class="mhd-left"><div class="mhd-icon" style="background:rgba(16,185,129,.15)">📋</div><div><div class="mhd-title" id="m-loan-title">Create Loan</div><div class="mhd-sub">New loan processing record</div></div></div>
   <div class="mc" onclick="closeM('m-loan')">✕</div>
  </div>
  <div class="mbody">
   <!-- Pension Info -->
   <div class="msec">
    <div class="msec-title">Pension Info</div>
    <div style="display:flex;gap:20px;align-items:flex-start">
     <div style="flex:1">
      <div class="fr">
       <div class="fg"><label>Pension Reference</label><input id="ln-pensref" placeholder="Pensioner"></div>
       <div class="fg"><label>Birth Date</label><div style="display:flex;gap:6px"><input type="date" id="ln-bdate" style="flex:1"><input type="number" id="ln-age" placeholder="0" style="width:60px;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:8px;padding:9px 10px;color:var(--text);font-family:inherit;outline:none;" readonly></div></div>
      </div>
      <div class="fr">
       <div class="fg"><label>Customer <span class="req">*</span></label><input id="ln-customer" placeholder="Customer Name"><div class="errmsg">Required</div></div>
       <div class="fg"><label>Contact Number</label><input id="ln-contact" placeholder="Contact Number"></div>
      </div>
      <div class="fr">
       <div class="fg"><label>Pension Provider</label><input id="ln-provider" placeholder="Pension Provider"></div>
       <div class="fg"><label>Pension Amount</label><input type="number" id="ln-pamount" value="0.00" step="0.01"></div>
      </div>
      <div class="fr">
       <div class="fg"><label>Pension Type</label><input id="ln-ptype" placeholder="Pension Type"></div>
       <div class="fg"><label>Withdrawable</label><input type="number" id="ln-withdraw" value="0.00" step="0.01"></div>
      </div>
      <div class="fr">
       <div class="fg"><label>Pension Number</label><input id="ln-pnum" placeholder="Pension Number"></div>
       <div class="fg"><label>Withdrawal Day</label><input type="number" id="ln-wday" value="0"></div>
      </div>
      <div class="fg"><label>Months Remaining</label><input id="ln-months" placeholder="Months Remaining" style="max-width:250px"></div>
     </div>
     <div class="avatar-box" onclick="toast('📷 Photo upload','warn')"><span>👤</span><p>Click to<br>upload photo</p></div>
    </div>
   </div>
   <!-- Loan Info -->
   <div class="msec">
    <div class="msec-title">Loan Info</div>
    <div class="fr">
     <div class="fg"><label>Loan Reference</label><input id="ln-loanref" class="readonly" value="Automatic" readonly></div>
     <div class="fg"><label>Branch Name</label><input id="ln-branch" value="Malolos"></div>
    </div>
    <div class="fr">
     <div class="fg"><label>Loan Date <span class="req">*</span></label><input type="date" id="ln-ldate"></div>
     <div class="fg"><label>Agent</label><select id="ln-agent"><option></option><option>Ana Santos</option><option>Roberto Cruz</option><option>Maria Dela Cruz</option></select></div>
    </div>
    <div class="fr">
     <div class="fg"><label>Loan Type</label><select id="ln-loantype"><option></option><option>New</option><option>Renewal</option><option>Extension</option><option>Buy-Out</option></select></div>
     <div class="fg"><label>Loan Receivable</label><select id="ln-receivable"><option></option><option>Type A</option><option>Type B</option></select></div>
    </div>
    <div class="fr">
     <div class="fg"><label>Product</label><select id="ln-product"><option></option><option>Loan-70a</option><option>Loan-72a</option><option>Loan-75a</option><option>Loan-70x</option><option>Loan-70n</option><option>Loan-70r</option><option>BONUS LOAN August</option></select></div>
     <div class="fg"><label>Co-Maker Name</label><div style="display:flex;gap:5px"><input id="ln-comaker" placeholder="Co-Maker" style="flex:1"><button class="btn btn-xs btn-secondary" onclick="toast('➕ Add co-maker','warn')">+</button><button class="btn btn-xs btn-secondary" onclick="toast('✏️ Edit co-maker','warn')">✏️</button></div></div>
    </div>
    <div class="fr">
     <div class="fg"><label>Relation</label><input id="ln-relation" placeholder="Relation"></div>
     <div class="fg"><label>Source of Income</label><select id="ln-income"><option></option><option>SSS Pension</option><option>GSIS Pension</option><option>Employment</option></select></div>
    </div>
    <label class="chk-row"><input type="checkbox" id="ln-active" checked> Is Active</label>
   </div>
   <!-- Loan Computation -->
   <div class="msec">
    <div class="msec-title">Loan Computation</div>
    <div style="display:flex;gap:20px">
     <div style="width:220px;flex-shrink:0">
      <div class="fg"><label>Amortization <span class="req">*</span></label><input type="number" id="ln-amort" value="0.00" step="0.01" oninput="calcLoan()"></div>
      <div class="fg"><label>Terms</label><input type="number" id="ln-terms" value="12" min="1" oninput="calcLoan()"></div>
      <div class="fg"><label>Principal</label><input type="number" id="ln-principal" value="0.00" readonly class="readonly" step="0.01"></div>
      <div class="fg"><label>Processing Fee</label><input type="number" id="ln-proc" value="0.00" step="0.01" oninput="calcLoan()"></div>
      <div class="fg"><label>Notarial Fee</label><input type="number" id="ln-not" value="0.00" step="0.01" oninput="calcLoan()"></div>
      <div class="fg"><label>Collection Fee</label><input type="number" id="ln-colfee" value="0.00" step="0.01" oninput="calcLoan()"></div>
      <div class="fg"><label>Insurance Fee</label><input type="number" id="ln-ins" value="0.00" step="0.01" oninput="calcLoan()"></div>
      <div class="fg"><label>Interest</label><input type="number" id="ln-interest" value="0.00" readonly class="readonly" step="0.01"></div>
      <div class="fg"><label>Deductions</label><input type="number" id="ln-deductions" value="0.00" readonly class="readonly" step="0.01"></div>
      <div class="fg"><label>Gross Cash Out</label><input type="number" id="ln-gross" value="0.00" readonly class="readonly" step="0.01"></div>
      <div class="fg"><label>Loan Receivable</label><input type="number" id="ln-loanrecv" value="0.00" step="0.01"></div>
      <div class="fg"><label style="color:var(--emerald)">Net Cash Out</label><input type="number" id="ln-net" value="0.00" readonly class="readonly" step="0.01" style="border-color:rgba(16,185,129,.3);color:var(--emerald);font-weight:700;font-size:15px"></div>
     </div>
     <div style="flex:1">
      <div style="font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text3);margin-bottom:8px">Amortization Schedule</div>
      <div class="sub-table-wrap"><table class="sched-table" id="sched-table"><thead><tr><th>#</th><th>Due Date</th><th>Earned</th><th>Unearned</th><th>Balance</th></tr></thead><tbody id="sched-body"><tr><td colspan="5" class="sub-empty">Enter amortization and terms to generate schedule</td></tr></tbody></table></div>
     </div>
    </div>
   </div>
   <div class="meta-bar"><span>Created: —</span><span>Updated: —</span></div>
  </div>
  <div class="mft">
   <button class="btn btn-secondary" onclick="closeM('m-loan')">✕ Cancel</button>
   <button class="btn btn-primary" onclick="saveLoan()">💾 Save Loan</button>
  </div>
 </div>
</div>

